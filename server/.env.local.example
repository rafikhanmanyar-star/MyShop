# Local Development with PostgreSQL

# Option 1: Use Render Cloud Database (requires network access)
# DATABASE_URL=postgresql://myshop_db_staging_user:1svMSUH15ssv1LA0AVYPVJSHaWy2lfEj@dpg-d6aqlkumcj7s73ekis60-a.oregon-postgres.render.com/myshop_db_staging

# Option 2: Use Local PostgreSQL
# Make sure PostgreSQL is running locally
# DATABASE_URL=postgresql://postgres:password@localhost:5432/myshop_local

# Option 3: Disable migrations for development (when database is not available)
# DISABLE_MIGRATIONS=true
# DATABASE_URL=postgresql://user:password@localhost:5432/myshop

JWT_SECRET=myshop-dev-secret-change-in-production
PORT=3001
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5180,http://localhost:5190
NODE_ENV=development

# When DATABASE_URL points at Render but you run the API locally, voice/product files live on Render disk.
# Set this so missing local files under server/uploads are proxied from production/staging API.
REMOTE_UPLOADS_ORIGIN=https://myshop-api-9pd4.onrender.com

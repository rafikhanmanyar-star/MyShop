{
  "name": "myshop",
  "version": "1.1.24",
  "description": "MyShop - POS & Inventory Management",
  "main": "electron/main.js",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/rafikhanmanyar-star/MyShop.git"
  },
  "scripts": {
    "dev": "node scripts/run-dev.mjs dev",
    "dev:apps": "node scripts/run-dev.mjs apps",
    "dev:stop": "node scripts/kill-dev-ports.mjs",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "dev:pos:cloud": "cd client && npm run dev:cloud",
    "dev:mobile": "cd mobile && npm run dev",
    "dev:rider": "cd rider && npm run dev",
    "dev:website": "cd website && npm run dev",
    "build:website": "cd website && npm run build",
    "fetch:website": "powershell -ExecutionPolicy Bypass -File ./fetch-website.ps1",
    "build": "npm run build:server && npm run build:client",
    "build:server": "cd server && npm run build",
    "migrate": "cd server && npm run migrate",
    "check:typography": "cd client && npm run check:typography",
    "build:client": "cd client && npm run build",
    "build:client:cloud": "cd client && npm run build:cloud",
    "electron": "npm run build && electron .",
    "electron:dev": "node scripts/run-dev.mjs electron",
    "electron:cloud": "npm run build:client:cloud && electron . --cloud",
    "pack": "npm run build:client:cloud && electron-builder --dir -c electron-builder.cloud.json",
    "pack:local": "npm run build && electron-builder --dir",
    "dist": "npm run build:client:cloud && electron-builder -c electron-builder.cloud.json",
    "dist:win": "npm run build:client:cloud && electron-builder --win -c electron-builder.cloud.json",
    "dist:local": "npm run build && electron-builder",
    "dist:win:local": "npm run build && electron-builder --win",
    "release": "powershell -ExecutionPolicy Bypass -File ./build-and-push.ps1",
    "release:minor": "powershell -ExecutionPolicy Bypass -File ./build-and-push.ps1 -BumpType minor",
    "release:major": "powershell -ExecutionPolicy Bypass -File ./build-and-push.ps1 -BumpType major",
    "postinstall": "cd server && npm install && cd ../client && npm install && cd ../mobile && npm install && cd ../rider && npm install && cd ../website && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.2.0",
    "electron-builder": "^26.7.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.myshop.app",
    "productName": "MyShop",
    "icon": "build/icon.png",
    "afterPack": "scripts/afterPack.js",
    "directories": {
      "output": "release"
    },
    "files": [
      "package.json",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "server",
        "to": "server",
        "filter": [
          "dist/**/*",
          "migrations/**/*",
          "package.json",
          "node_modules/**/*",
          ".env"
        ]
      },
      {
        "from": "client/dist",
        "to": "client/dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "MyShop"
    }
  }
}
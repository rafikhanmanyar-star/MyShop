# =============================================================================
# MyShop Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values

# PostgreSQL Connection (Render External URL)
# Format: postgresql://user:pass@dpg-xxx-a.region-postgres.render.com:5432/dbname
DATABASE_URL=postgresql://myshop_user:vcxIseFD76CaG76lBCYVeUaYDiIe83qr@dpg-d6arbkq48b3s73bgumgg-a.oregon-postgres.render.com/myshop_d6mh

# JWT Secret (generate a strong random string)
JWT_SECRET=your-secret-here-change-this

# Server Port
PORT=3001

# CORS Origins (comma-separated)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5180,http://localhost:5190

# Web Push (rider PWA) — generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourshop.com

# Google Maps (server ETA + route optimization)
GOOGLE_MAPS_API_KEY=

# Environment
NODE_ENV=development

# Disable migrations (optional)
# DISABLE_MIGRATIONS=true

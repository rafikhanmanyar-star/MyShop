{
  "name": "mobile",
  "private": true,
  "version": "1.1.19",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate-icons": "node scripts/generate-pwa-icons.mjs",
    "generate-android-icons": "node scripts/generate-android-icons.mjs",
    "build": "npm run generate-icons && npm run generate-android-icons && tsc -b && vite build",
    "cap:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "android:assembleDebug": "powershell -ExecutionPolicy Bypass -File ../android/scripts/run-gradle.ps1 assembleDebug",
    "android:assembleRelease": "powershell -ExecutionPolicy Bypass -File ../android/scripts/run-gradle.ps1 assembleRelease",
    "android:bundleRelease": "powershell -ExecutionPolicy Bypass -File ../android/scripts/build-play-aab.ps1",
    "android:bundleRelease:gradle": "powershell -ExecutionPolicy Bypass -File ../android/scripts/run-gradle.ps1 bundleRelease",
    "android:verify-keystore": "powershell -ExecutionPolicy Bypass -File ../android/scripts/verify-keystore.ps1",
    "android:create-keystore": "powershell -ExecutionPolicy Bypass -File ../android/scripts/create-release-keystore.ps1",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor-firebase/analytics": "^6.3.1",
    "@capacitor-firebase/crashlytics": "^6.3.1",
    "@capacitor-firebase/messaging": "^6.3.1",
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.3",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/geolocation": "^6.1.1",
    "@capacitor/status-bar": "^6.0.3",
    "@react-google-maps/api": "^2.20.8",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-virtual": "^3.13.23",
    "firebase": "^10.14.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/google.maps": "^3.64.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "sharp": "^0.34.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0"
  }
}
